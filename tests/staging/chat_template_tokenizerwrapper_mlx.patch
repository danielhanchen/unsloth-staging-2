diff --git a/unsloth/chat_templates.py b/unsloth/chat_templates.py
index b18e4575e..2a76fb105 100644
--- a/unsloth/chat_templates.py
+++ b/unsloth/chat_templates.py
@@ -1855,6 +1855,20 @@ def get_chat_template(
         use_zoo_tokenizer_patch = is_mlx_backend
     old_tokenizer = tokenizer
 
+    # mlx-lm wraps the HF tokenizer in a TokenizerWrapper whose `_tokenizer`
+    # attribute is the HF tokenizer (not the Rust backend). The vocab-editing
+    # paths below assume an HF tokenizer (`._tokenizer` is the Rust backend and
+    # `tokenizer.__class__(tokenizer_object=...)` rebuilds it), so unwrap to the
+    # HF tokenizer here and re-wrap the (possibly rebuilt) tokenizer before
+    # returning. This makes get_chat_template's map_eos_token / token-mapping
+    # paths work for mlx-community models on Apple Silicon. No-op off MLX.
+    _mlx_tokenizer_wrapper = None
+    if is_mlx_backend and tokenizer.__class__.__name__ == "TokenizerWrapper":
+        _inner_tokenizer = getattr(tokenizer, "_tokenizer", None)
+        if _inner_tokenizer is not None and hasattr(_inner_tokenizer, "is_fast"):
+            _mlx_tokenizer_wrapper = tokenizer
+            tokenizer = _inner_tokenizer
+
     IS_GEMMA = False
     if tokenizer.__class__.__name__.startswith("Gemma"):
         if chat_template == "chatml": chat_template = "gemma_chatml"
@@ -2078,6 +2092,13 @@ def get_chat_template(
     # Add Ollama
     tokenizer._ollama_modelfile = ollama_modelfile
     tokenizer._system_message   = system_message
+
+    # Re-wrap the (possibly rebuilt) HF tokenizer back into the mlx-lm wrapper so
+    # the trainer receives the same type FastLanguageModel returned. Attribute
+    # reads (chat_template, _ollama_modelfile, ...) delegate through the wrapper.
+    if _mlx_tokenizer_wrapper is not None:
+        _mlx_tokenizer_wrapper._tokenizer = tokenizer
+        tokenizer = _mlx_tokenizer_wrapper
     return tokenizer#, stopping_criteria
 
 
